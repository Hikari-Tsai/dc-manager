# Discord Bot Token。請填入你的機器人權杖。
DISCORD_TOKEN=

# 要監控的 Discord 頻道 ID，多個頻道請用逗號分隔。
SOURCE_CHANNEL_IDS=

# 定期發布統計摘要的頻道 ID。
STATS_CHANNEL_ID=

# 接收 AI 審核警示的私人或管理員頻道 ID。
MOD_LOG_CHANNEL_ID=

# OpenAI API 金鑰預設留空。啟用 AI 檢查時請手動填入。
OPENAI_API_KEY=

# AI 審核使用的 OpenAI 模型名稱。
OPENAI_MODEL=gpt-4.1-mini

# 統計設定
# 統計報告排程，使用 cron 格式。預設為每日 00:00 執行一次。
STATS_INTERVAL_CRON="0 0 * * *"

# 啟動時往回抓幾小時的歷史訊息做初始統計。設為 0 可停用回抓。
STATS_BACKFILL_HOURS=6

# 發送統計報告後是否重置統計資料。
STATS_RESET_AFTER_REPORT=true

# 要追蹤的關鍵字，多個關鍵字請用逗號分隔。留空代表不追蹤特定關鍵字。
KEYWORDS=

# 統計熱門詞彙時顯示的最多詞數。
TOP_WORD_LIMIT=10

# AI 審核設定
# 是否啟用 AI 內容審核。
ENABLE_AI_MODERATION=true

# 偵測到違規訊息時的處理方式。log 表示只記錄到管理頻道。
MODERATION_ACTION=log

# 直接回覆使用者的提醒文字。
DIRECT_REPLY_TEXT=你的訊息可能違反版規，請調整語氣或內容。

# 是否刪除被判定違規的訊息。
DELETE_VIOLATING_MESSAGES=false

# 訊息長度達到此字數以上才送交 AI 審核。
MIN_MESSAGE_LENGTH_FOR_AI=3

# 版規 txt 檔案路徑。設定後會優先使用此檔案；若檔案讀不到，程式會啟動失敗。
RULES_FILE=rules.txt

# 伺服器規則文字。建議保持簡短且具體，供 AI 審核時參考。
# 未設定 RULES_FILE 時才會使用此欄位。
RULES_TEXT=禁止人身攻擊、歧視、騷擾、洗頻、惡意連結、NSFW 內容與洩漏個資。
